{
	chapter.4AEC50DD960A89FD.title: "The Journey Reborn"
	quest.168A0785876D42EB.quest_subtitle: "This Modpack contains Draconic Evolution and Draconic Additions"
	quest.2F6F1248E5C7C957.quest_desc: [
		"the mod spectrum is a exploration, progression based magic mod"
		""
		"once you find one of the 3 base shards (amethyst, topaz or citrine)"
		"the mod will give you a guide book, that alongside the mods advancements"
		"will guide you thru its progression"
		""
		"its meant to be progressed thru as you continue to progress thru the game itself"
	]
	quest.2F6F1248E5C7C957.quest_subtitle: "this modpack also contains the mod Spectrum"
	quest.32C7CFCE861342F8.quest_subtitle: "Modpack Also Contains Better Furnace's Reforged"
	quest.3FC60CCB8EE40274.quest_desc: [
		"the modpack contains create, and some addons, one of which is"
		"create aeronautics, a long awaited addon"
		""
		"with it, you can make airships, planes and cars, among other things"
	]
	quest.3FC60CCB8EE40274.quest_subtitle: "The Modpack's Main Mod - Create Aeronautics"
