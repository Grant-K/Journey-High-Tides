	quest.5316EF06AD8BD7C1.quest_subtitle: "The Start Of The Journey"
	quest.67B15EF9A2B5E448.quest_desc: [
		"across the world, as you explore, you will encounter *alot* of structres"
		""
		"some with loot, some with enemies to fight for said loot"
		""
		"some with minibosses to fight to get access to the loot"
	]
	quest.67B15EF9A2B5E448.quest_subtitle: "This Modpack Has *alot* of structres to explore and loot"
	quest.67B15EF9A2B5E448.title: "Info 8"
	quest.746AE0EA99323DEA.quest_desc: [
		"Apotheosis allows the player to enchant gear beyond the vanilla limit"
		""
		"also allowing the player to \"upgrade\" armor and tools into apothic tiered gear"
		""
		"with those apothic tiered items, sometimes they might have \"sockets\", that can be slotted with gems"
		""
		"as you progess thru the apothic world tier system you will unlock the ability to find higher rarity gear and gems and via gateways of eternity you will be able to fight apothic mini bosses and enemies"
	]
	quest.746AE0EA99323DEA.quest_subtitle: "This Modpack contains Apotheosis And Enchanting Infuser"
	quest.746AE0EA99323DEA.title: "Info 4"
